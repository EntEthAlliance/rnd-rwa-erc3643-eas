    subgraph After["AFTER: Open Attestation Layer"]
        direction TB
        A_Investor["👤 Investor"]
        A_Provider1["KYC Provider A"]
        A_Provider2["KYC Provider B"]
        A_Provider3["KYC Provider C"]
