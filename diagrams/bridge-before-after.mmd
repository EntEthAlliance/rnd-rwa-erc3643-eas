        A_Token2["Token on Base"]
        A_Token3["Token on Arbitrum"]

        A_Investor -->|"KYC once"| A_Provider1
        A_Investor -.->|"or"| A_Provider2
        A_Investor -.->|"or"| A_Provider3
        A_Provider1 -->|"attestation"| A_EAS
        A_Provider2 -->|"attestation"| A_EAS
        A_Provider3 -->|"attestation"| A_EAS
        A_EAS -->|"verify"| A_Bridge
        A_Bridge -->|"isVerified()"| A_Token1
        A_Bridge -->|"isVerified()"| A_Token2
        A_Bridge -->|"isVerified()"| A_Token3
    end

