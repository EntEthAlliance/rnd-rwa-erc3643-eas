sequenceDiagram
    %% Mirrors OpenZeppelin RWA vocabulary: token → compliance → identity verifier module
    participant User
    participant Token as Token Core (ERC-3643)
    participant Compliance as Compliance Module(s)
    participant IR as Identity Registry
    participant Verifier as Identity Verifier (EASClaimVerifier)
    participant EIP as Wallet→Identity Mapping (EASIdentityProxy)
    participant CTR as Claim Topics Registry
    participant TIA as Trusted Attesters Adapter
    participant EAS as EAS.sol

    User->>Token: transfer(to, amount)
    Token->>Compliance: canTransfer(from, to, amount)

    %% ERC-3643: compliance gates call into identity checks (via Identity Registry)
    Compliance->>IR: isVerified(to)

    Note over IR,Verifier: Identity Verifier Module — EAS backend (pluggable)
    IR->>Verifier: isVerified(userAddress)

    Verifier->>EIP: getIdentity(userAddress)
    EIP-->>Verifier: identityAddress

    Verifier->>CTR: getClaimTopics()
    CTR-->>Verifier: [topic1, topic2, ...]

    loop For each required claim topic
        Verifier->>Verifier: topic→schemaUID mapping
        Verifier->>TIA: getTrustedAttestersForTopic(topic)
        TIA-->>Verifier: [attester1, attester2, ...]

        loop For each trusted attester
            Verifier->>Verifier: find registered attestation UID
            alt Attestation UID exists
                Verifier->>EAS: getAttestation(uid)
                EAS-->>Verifier: Attestation{uid, schema, revocationTime, expirationTime, data}
                Verifier->>Verifier: validate(notRevoked, notExpired, schemaMatch, attesterTrusted)
                alt Valid attestation found
                    Note over Verifier: Topic satisfied
                end
            end
        end
    end

    Verifier-->>IR: true/false
    IR-->>Compliance: verified/not verified
    Compliance-->>Token: canTransfer result

    alt Transfer allowed
        Token->>Token: Execute transfer
        Token-->>User: Transfer success
    else Transfer blocked
        Token-->>User: Transfer failed (identity/compliance)
    end
