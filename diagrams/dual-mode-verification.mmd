flowchart TD
    Start([Token Transfer Request])
    IR{"Identity Registry\n(uses a pluggable Identity Verifier module)"}

    subgraph OnchainIDPath["Identity Verifier Module — ONCHAINID"]
        OCID_Check{"Has ONCHAINID\nIdentity?"}
        IRS["IdentityRegistryStorage"]
        OCID["IIdentity Contract (ONCHAINID)"]
        CI["IClaimIssuer"]
        OCID_Valid{"Claims Valid?"}
    end

    subgraph EASPath["Identity Verifier Module — EAS"]
        EAS_Enabled{"EAS verifier\nenabled?"}
        ECV["EASClaimVerifier\n(EAS Identity Verifier)"]
        EIP["EASIdentityProxy\n(wallet→identity)"]
        TIA["EASTrustedIssuersAdapter\n(trusted attesters)"]
        EAS["EAS.sol"]
        EAS_Valid{"Attestations\nValid?"}
    end

    Verified([Verification Passed])
    NotVerified([Verification Failed])

    Start --> IR

    IR --> OCID_Check
    OCID_Check -->|Yes| IRS
    IRS --> OCID
    OCID --> CI
    CI --> OCID_Valid
    OCID_Valid -->|Yes| Verified
    OCID_Valid -->|No| EAS_Enabled

    OCID_Check -->|No| EAS_Enabled

    EAS_Enabled -->|Yes| ECV
    ECV --> EIP
    ECV --> TIA
    TIA --> EAS
    EAS --> EAS_Valid
    EAS_Valid -->|Yes| Verified
    EAS_Valid -->|No| NotVerified

    EAS_Enabled -->|No| NotVerified

    style Verified fill:#c8e6c9,stroke:#2e7d32
    style NotVerified fill:#ffcdd2,stroke:#c62828
    style ECV fill:#bbdefb,stroke:#1976d2
    style OCID fill:#e1bee7,stroke:#7b1fa2
