flowchart TB
    subgraph TokenLayer["ERC-3643 Token Layer"]
        Token[Token Contract]
        Compliance[Compliance Module]
        IR[Identity Registry]
    end

    subgraph BridgeLayer["EAS Bridge Layer"]
        ECV[EASClaimVerifier]
        TIA[EASTrustedIssuersAdapter]
        EIP[EASIdentityProxy]
        CTR[ClaimTopicsRegistry]
    end

    subgraph EASLayer["EAS Protocol Layer"]
        EAS[EAS.sol]
        SR[Schema Registry]
    end

    subgraph OnchainIDLayer["ONCHAINID Layer (Optional)"]
        OCID[ONCHAINID Contract]
        TIR[TrustedIssuersRegistry]
        IRS[IdentityRegistryStorage]
    end

    Token -->|canTransfer| Compliance
    Compliance -->|isVerified| IR

    IR -->|Path A: EAS| ECV
    IR -.->|Path B: ONCHAINID| IRS
    IRS -.-> OCID
    OCID -.-> TIR

    ECV -->|getIdentity| EIP
    ECV -->|getClaimTopics| CTR
    ECV -->|getTrustedAttesters| TIA
    ECV -->|getAttestation| EAS

    EAS --> SR

