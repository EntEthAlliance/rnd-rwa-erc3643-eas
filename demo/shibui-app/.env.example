# Sepolia RPC endpoint used by the demo UI (read/write).
# BYO-key (Alchemy/Infura/QuickNode/your own node) or default to a public RPC.
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://rpc.sepolia.org

# WalletConnect Cloud projectId — required for RainbowKit walletconnect connector.
# Get one at https://cloud.walletconnect.com (free).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional override: if you deployed Shibui on a fork / local Sepolia, point the UI here.
# Leave blank to use deployments/sepolia.json.
# NEXT_PUBLIC_DEPLOYMENT_OVERRIDE_URL=
