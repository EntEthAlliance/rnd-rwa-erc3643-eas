# Compiler files
cache/
out/

# Ignores development broadcast logs
!/broadcast
/broadcast/*/31337/
/broadcast/**/dry-run/

# Foundry generated docs (not our project docs)
docs/book/

# Dotenv file
.env

# Foundry / soldeer lockfile — we track dependencies via git submodules
# (see .gitmodules). The lockfile is regenerated on `forge install` and
# drifts from reality when submodules are added/removed.
foundry.lock
